{
  "name": "flex-template",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "bunx concurrently \"bun run dev:frontend\" \"bun run dev:backend\"",
    "dev:frontend": "vite --open",
    "dev:backend": "convex dev",
    "lint": "tsc -p convex -noEmit --pretty false && tsc -p . -noEmit --pretty false && convex dev --once && vite build"
  },
  "dependencies": {
    "@convex-dev/auth": "^0.0.80",
    "@tabler/icons-react": "^3.41.1",
    "@types/nodemailer": "^6.4.23",
    "chart.js": "^4.5.1",
    "clsx": "^2.1.1",
    "convex": "^1.34.1",
    "jspdf": "^3.0.4",
    "nodemailer": "^7.0.13",
    "pdfjs-dist": "^5.6.205",
    "react": "^19.2.4",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.4",
    "resend": "^4.8.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.19.17",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "~10.4.27",
    "concurrently": "^9.2.1",
    "dotenv": "^16.6.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^15.15.0",
    "postcss": "~8.5.8",
    "prettier": "^3.8.1",
    "sharp": "^0.34.5",
    "tailwindcss": "~3.4.19",
    "typescript": "~5.7.3",
    "typescript-eslint": "^8.58.0",
    "vite": "latest"
  },
  "prettier": {
    "useTabs": false,
    "tabWidth": 2,
    "singleQuote": true,
    "arrowParens": "avoid",
    "printWidth": 120,
    "trailingComma": "all",
    "semi": true
  }
}
